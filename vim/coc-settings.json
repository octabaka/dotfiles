
{
  "languageserver": {
		"bash": {
      "command": "bash-language-server",
      "args": ["start"],
      "filetypes": ["sh"],
      "ignoredRootPaths": ["~"]
    },
		"lua": {
      "command": "lua-lsp",
      "filetypes": ["lua"]
    },
		"ccls": {
      "command": "ccls",
      "filetypes": ["c", "cpp", "objc", "objcpp"],
      "rootPatterns": [".ccls", "compile_commands.json", ".git/", ".hg/"],
      "initializationOptions": {
         "cache": {
           "directory": "/tmp/ccls"
         }
       }
    }
  },
	"suggest.echodocSupport": true ,
	"coc.preferences.colorSupport": true,
	"coc.preferences.formatOnSaveFiletypes": ["typescript", "typescriptreact", "graphql", "go", "html"],
	"snippets.ultisnips.enable": true,
	"snippets.ultisnips.directories": ["~/dev/vim/snippets/"]
}
